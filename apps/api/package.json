{
  "name": "@m1s2/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed:admin": "tsx src/scripts/seed-admin.ts",
    "clear:events": "tsx src/scripts/clear-events.ts",
    "migrate:up": "migrate-mongo up -f migrate-mongo-config.cjs",
    "migrate:down": "migrate-mongo down -f migrate-mongo-config.cjs",
    "migrate:status": "migrate-mongo status -f migrate-mongo-config.cjs",
    "migrate:create": "migrate-mongo create -f migrate-mongo-config.cjs"
  },
  "dependencies": {
    "@m1s2/shared": "^0.0.0",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.24.1",
    "resend": "^6.17.2",
    "socket.io": "^4.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.13.2",
    "migrate-mongo": "^14.0.7",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
